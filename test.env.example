# Test Environment Configuration
# Copy this file to .env.test and update with your test values

# Environment
ENVIRONMENT=test

# Database
DATABASE_URL=postgresql://test:test@localhost:5432/test_db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Stripe (Test Keys)
STRIPE_SECRET_KEY=sk_test_dummy_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_dummy_key_here
STRIPE_WEBHOOK_SECRET=whsec_dummy_webhook_secret

# OpenAI (Test Key)
OPENAI_API_KEY=sk-dummy_openai_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Supabase (Test Configuration)
SUPABASE_URL=https://dummy-test.supabase.co
SUPABASE_ANON_KEY=dummy_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=dummy_service_role_key_here

# Clerk (Test Keys)
CLERK_SECRET_KEY=sk_test_dummy_clerk_key
CLERK_PUBLISHABLE_KEY=pk_test_dummy_clerk_key

# Application Settings
DEBUG=true
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
API_PREFIX=/api/v1

# Security
SECRET_KEY=dummy_secret_key_for_testing
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=pdf,docx,txt,md

# Cache Settings
REDIS_URL=redis://localhost:6379/1
CACHE_TTL=3600

# Monitoring
SENTRY_DSN=dummy_sentry_dsn
NEW_RELIC_LICENSE_KEY=dummy_new_relic_key 